{
  "manifest_version": 3,
  "name": "Download Accelerator",
  "version": "1.0.0",
  "description": "Download accelerator with parallel connections per file and concurrent downloads",
  "permissions": [
    "downloads",
    "downloads.open",
    "storage",
    "offscreen",
    "notifications",
    "contextMenus",
    "nativeMessaging",
    "cookies",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
